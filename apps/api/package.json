{
  "name": "@chessgg/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm run prisma:generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo 'No lint configured for API yet'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "test:smoke": "tsx src/scripts/smoke.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@sentry/node": "^10.20.0",
    "@supabase/supabase-js": "^2.53.0",
    "@chessgg/shared": "file:../../packages/shared",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^20.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "prisma": "^6.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
