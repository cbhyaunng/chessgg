generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

enum SubscriptionPlan {
  FREE
  PRO

  @@schema("public")
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  CANCELED
  PAST_DUE

  @@schema("public")
}

enum AnalysisJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED

  @@schema("public")
}

enum PlatformSyncStatus {
  IDLE
  SYNCING
  FAILED

  @@schema("public")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String?
  googleSub       String?         @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  refreshTokens   RefreshToken[]
  subscription    Subscription?
  analysisUsages  AnalysisUsage[]
  analysisJobs    AnalysisJob[]

  @@schema("public")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String             @unique
  plan                  SubscriptionPlan   @default(FREE)
  status                SubscriptionStatus @default(INACTIVE)
  stripeCustomerId      String?            @unique
  stripeSubscriptionId  String?            @unique
  periodEnd             DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model BillingWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  receivedAt    DateTime @default(now())

  @@schema("public")
}

model AnalysisUsage {
  id           String   @id @default(cuid())
  userId       String
  usageDate    DateTime
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, usageDate])
  @@index([userId])
  @@schema("public")
}

model AnalysisJob {
  id           String            @id @default(cuid())
  userId       String
  platform     String
  username     String
  platformGameId String
  status       AnalysisJobStatus @default(QUEUED)
  requestedAt  DateTime          @default(now())
  finishedAt   DateTime?
  errorMessage String?
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, requestedAt])
  @@schema("public")
}

model PlatformProfileCache {
  id                  String             @id @default(cuid())
  platform            String
  usernameLower       String
  usernameDisplay     String
  profileJson         Json
  gamesCount          Int                @default(0)
  latestPlayedAt      DateTime?
  lastFullSyncAt      DateTime?
  lastIncrementalSyncAt DateTime?
  staleAt             DateTime
  syncStatus          PlatformSyncStatus @default(IDLE)
  syncStartedAt       DateTime?
  syncFinishedAt      DateTime?
  syncError           String?
  isTruncated         Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  games               PlatformGameCache[]

  @@unique([platform, usernameLower])
  @@index([platform, staleAt])
  @@schema("public")
}

model PlatformGameCache {
  id             String               @id @default(cuid())
  profileCacheId String
  platformGameId String
  url            String
  playedAt       DateTime
  timeControl    String
  timeControlCategory String
  rated          Boolean
  color          String
  result         String
  opponentUsername String
  opponentRating Int?
  playerRating   Int?
  opening        String?
  eco            String?
  pgn            String?
  totalMoves     Int?
  timeSpentSec   Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  profileCache   PlatformProfileCache @relation(fields: [profileCacheId], references: [id], onDelete: Cascade)

  @@unique([profileCacheId, platformGameId])
  @@index([profileCacheId, playedAt])
  @@index([profileCacheId, timeControlCategory, playedAt])
  @@schema("public")
}
