NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

JWT_ACCESS_SECRET=replace-with-long-random-string-access
JWT_REFRESH_SECRET=replace-with-long-random-string-refresh
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_SEC=2592000
GOOGLE_CLIENT_ID=

GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

ANALYSIS_DAILY_LIMIT_FREE=2
ANALYSIS_DAILY_LIMIT_PRO=30

DATASET_TTL_MS=300000
CHESSCOM_MAX_ARCHIVES=12
LICHESS_MAX_GAMES=200

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_BILLING_SUCCESS_URL=https://your-domain.com/account/billing?checkout=success
STRIPE_BILLING_CANCEL_URL=https://your-domain.com/pricing?checkout=cancel

SENTRY_DSN=
